{
  "name": "fb-group-monitor-skill-v6-2-2",
  "version": "6.2.2",
  "description": "Reusable Codex skill for two-stage Facebook game group monitoring with V6.2.2 prompt-driven, run-local shutdown policy resolution (default no shutdown), deadline-aware forced shutdown, strong language precedence, transient GeoNames retries, reboot-safe checkpoints, and self-deleting scheduled tasks.",
  "private": true,
  "scripts": {
    "login": "powershell -ExecutionPolicy Bypass -File .\\scripts\\open_chrome_9222.ps1",
    "phase1": "node .\\scripts\\phase1_collect_candidates.js",
    "phase2": "node .\\scripts\\phase2_collect_details.js",
    "monitor": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_multi_games_v2.ps1",
    "validate-login": "node .\\scripts\\validate_login_state.js",
    "login:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task login",
    "validate-login:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task validate-login",
    "phase1:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task phase1",
    "phase2:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task phase2",
    "monitor:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task monitor",
    "status:bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\show_background_task_status.ps1",
    "phase2:direct-bg": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start_background_task.ps1 -Task phase2 -DirectBackground"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "xlsx": "^0.18.5"
  }
}
